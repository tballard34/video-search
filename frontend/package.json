{
  "name": "video-search",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n web,api -c blue,green \"vite\" \"tsx server/dev-api.ts\"",
    "dev:web": "vite",
    "dev:api": "tsx server/dev-api.ts",
    "build": "tsc && vite build",
    "lint": "oxlint --report-unused-disable-directives",
    "lint:fix": "oxlint --fix --report-unused-disable-directives",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "preview": "vite preview",
    "test": "vitest run",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@tailwindcss/container-queries": "0.1.1",
    "@tanstack/react-query": "5.100.9",
    "@tanstack/react-query-devtools": "5.100.9",
    "@tanstack/react-router": "1.168.24",
    "@tanstack/react-router-devtools": "1.166.13",
    "@tanstack/router-plugin": "1.167.27",
    "@uploadthing/react": "^7.3.3",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-dropzone": "14.3.8",
    "react-icons": "5.6.0",
    "streamdown": "2.5.0",
    "tailwind-merge": "3.5.0",
    "uploadthing": "^7.7.4",
    "zod": "4.4.2"
  },
  "devDependencies": {
    "@tailwindcss/typography": "0.5.19",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.6.0",
    "@vitest/ui": "4.1.5",
    "autoprefixer": "10.5.0",
    "concurrently": "^10.0.3",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jsdom": "26.1.0",
    "oxfmt": "0.47.0",
    "oxlint": "1.62.0",
    "postcss": "8.5.13",
    "tailwindcss": "3.4.17",
    "tailwindcss-animate": "1.0.7",
    "tsx": "^4.22.4",
    "typescript": "6.0.3",
    "vite": "6.3.5",
    "vitest": "4.1.5"
  },
  "engines": {
    "node": "24.15.0"
  },
  "packageManager": "pnpm@10.33.2"
}
