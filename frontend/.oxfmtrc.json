{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 150,
  "ignorePatterns": [
    "dist",
    "build",
    "node_modules",
    "coverage",
    ".vite",
    ".vercel",
    "pnpm-lock.yaml",
    "src/routeTree.gen.ts",
    "*.tsbuildinfo",
    "*.min.js",
    "*.min.css"
  ],
  "sortImports": true,
  "sortTailwindcss": { "functions": ["cn", "clsx", "cva"] },
  "sortPackageJson": {}
}
