{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "ignorePatterns": ["dist", "build", "node_modules", "coverage", ".vite", ".vercel", ".tanstack", "src/routeTree.gen.ts", "*.tsbuildinfo"],
  "plugins": ["eslint", "oxc", "react", "unicorn", "typescript", "import"],
  "categories": {
    "correctness": "warn",
    "suspicious": "warn",
    "perf": "warn"
  },
  "rules": {
    "react-in-jsx-scope": "off",
    "eslint/no-shadow": "off",
    "eslint/no-await-in-loop": "off",
    "import/no-unassigned-import": ["warn", { "allow": ["**/*.css", "@testing-library/jest-dom"] }]
  },
  "overrides": [
    {
      "files": ["src/**/*.{ts,tsx}"],
      "rules": {
        "no-unused-vars": [
          "warn",
          {
            "argsIgnorePattern": "^_",
            "varsIgnorePattern": "^_",
            "caughtErrorsIgnorePattern": "^_"
          }
        ],
        "prefer-const": "error",
        "no-var": "error",
        "react/rules-of-hooks": "error",
        "react/only-export-components": ["warn", { "allowConstantExport": true }],
        "typescript/consistent-type-imports": ["warn", { "prefer": "type-imports" }]
      }
    }
  ]
}
